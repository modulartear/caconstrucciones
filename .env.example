PORT=3001

# Firebase
FIREBASE_DATABASE_URL=https://tu-proyecto.firebaseio.com
FIREBASE_SERVICE_ACCOUNT_KEY=./tu-service-account.json
# En Vercel usar JSON directo:
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Replicate - Probador de Materiales con IA
# Obtén tu token en: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# OpenAI - Visualizador IA
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1.5
OPENAI_IMAGE_QUALITY=low
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_MAX_INPUT_WIDTH=1024
FREE_GENERATIONS_LIMIT=2
