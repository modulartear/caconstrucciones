{
  "version": 2,
  "ignoreCommand": "if [ \"$VERCEL_GIT_COMMIT_REF\" != \"main\" ]; then echo \"Skipping non-main deployment\"; exit 0; else exit 1; fi",
  "outputDirectory": "frontend",
  "routes": [
    {
      "src": "/api/templates",
      "dest": "/api/visualizador?action=templates"
    },
    {
      "src": "/api/materials",
      "dest": "/api/visualizador?action=materials"
    },
    {
      "src": "/api/usage/(.*)",
      "dest": "/api/visualizador?action=usage&sessionId=$1"
    },
    {
      "src": "/api/template-masks",
      "dest": "/api/visualizador?action=template-masks"
    },
    {
      "src": "/api/generate",
      "dest": "/api/visualizador?action=generate"
    },
    {
      "src": "/api/leads",
      "dest": "/api/visualizador?action=leads"
    },
    {
      "src": "/api/visualizador-budget",
      "dest": "/api/visualizador?action=budget"
    },
    {
      "src": "/api/save-mask",
      "dest": "/api/visualizador?action=save-mask"
    },
    {
      "src": "/api/restore-mask",
      "dest": "/api/visualizador?action=restore-mask"
    },
    {
      "src": "/api/visualize",
      "dest": "/api/visualizador?action=legacy-visualize"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*\\.html?)$",
      "dest": "/$1"
    },
    {
      "src": "/(.*\\.jsx?)$",
      "dest": "/$1"
    },
    {
      "src": "/(.*\\.css)$",
      "dest": "/$1"
    },
    {
      "src": "/(.*\\.(png|jpg|jpeg|webp|svg))$",
      "dest": "/$1"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}
